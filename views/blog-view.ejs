<%- include('partials/header') %>

<!-- BLOG VIEW HERO -->
<section class="section-padding" style="background-image: linear-gradient(135deg, rgba(17, 24, 39, 0.9) 0%, rgba(31, 41, 55, 0.8) 100%), url('<%= blog.image %>?v=4'); background-size: cover; background-position: center; color: #ffffff; padding: 80px 30px 60px;">
    <div class="container">
        <div class="breadcrumbs" style="margin-bottom: 20px;">
            <a href="/"><i class="fa fa-home"></i> Home</a>
            <span class="separator">/</span>
            <span style="color: rgba(255,255,255,0.7);">Company</span>
            <span class="separator">/</span>
            <a href="/blog" style="color: rgba(255,255,255,0.7);">Travel Blog</a>
            <span class="separator">/</span>
            <span class="current"><%= blog.title %></span>
        </div>
        <h1 style="color: #ffffff; font-size: 2.8rem; line-height: 1.25; margin-bottom: 15px;"><%= blog.title %></h1>
        <p style="font-size: 0.95rem; color: var(--text-light); opacity: 0.85;">Published on <%= blog.publish_date %> | By <%= blog.author %></p>
    </div>
</section>

<!-- BLOG CONTENT -->
<section class="section-padding">
    <div class="container">
        <div class="hero-grid" style="align-items: start; gap: 50px;">
            <div>
                <div class="fleet-img-box" style="border-radius: var(--radius-md); overflow: hidden; box-shadow: var(--shadow-lg); margin-bottom: 30px;">
                    <img src="<%= blog.image %>?v=4" class="fleet-img" alt="<%= blog.title %>">
                </div>
                
                <p style="font-size: 1.15rem; line-height: 1.8; color: var(--text-main); white-space: pre-line; margin-bottom: 30px;"><%= blog.content %></p>
                
                <div style="margin-top: 40px; padding-top: 20px; border-top: 1px solid rgba(0,0,0,0.05); display: flex; gap: 10px; flex-wrap: wrap;">
                    <strong style="color: var(--primary-dark); margin-right: 10px;">Tags:</strong>
                    <% blog.tags.split(',').forEach(tag => { %>
                        <span style="background-color: var(--bg-main); color: var(--text-muted); font-size: 0.8rem; font-weight: 600; padding: 4px 12px; border-radius: var(--radius-sm);"><%= tag.trim() %></span>
                    <% }) %>
                </div>
            </div>

            <div>
                <!-- SIDEBAR RECENT POSTS -->
                <div class="admin-card" style="padding: 30px; border-radius: var(--radius-lg); position: sticky; top: 100px;">
                    <h3 style="margin-bottom: 20px; border-bottom: 2px solid var(--bg-main); padding-bottom: 10px; font-size: 1.3rem;">Other Travel Guides</h3>
                    
                    <div style="display: flex; flex-direction: column; gap: 20px;">
                        <% relatedBlogs.forEach(rel => { %>
                            <div style="display: flex; gap: 12px; align-items: start;">
                                <div style="width: 80px; height: 60px; background-color: var(--primary-medium); border-radius: var(--radius-sm); overflow: hidden; flex-shrink: 0; position: relative;">
                                    <img src="<%= rel.image %>?v=2" style="position: absolute; width: 100%; height: 100%; object-fit: cover;" alt="<%= rel.title %>">
                                </div>
                                <div>
                                    <h4 style="font-size: 0.95rem; font-weight: 700; line-height: 1.3; margin-bottom: 5px; height: 38px; overflow: hidden;"><a href="/blog/<%= rel.slug %>" style="color: var(--primary-dark);"><%= rel.title %></a></h4>
                                    <span style="font-size: 0.75rem; color: var(--text-muted);"><%= rel.publish_date %></span>
                                </div>
                            </div>
                        <% }) %>
                    </div>

                    <a href="/reservation" class="btn-primary" style="display: block; text-align: center; margin-top: 30px; font-size: 1rem; padding: 10px 0;">Request Event Shuttle Quote</a>
                </div>
            </div>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
