<%- include('partials/header') %>

<!-- THANK YOU CARD -->
<section class="section-padding" style="background-color: var(--bg-main); min-height: 70vh; display: flex; align-items: center;">
    <div class="container" style="max-width: 700px; text-align: center;">
        <div class="admin-card" style="padding: 50px 40px; border-radius: var(--radius-lg); box-shadow: var(--shadow-lg);">
            <div style="font-size: 4rem; color: #03543f; margin-bottom: 25px;">
                <i class="fa fa-check-circle"></i>
            </div>
            
            <h1 style="font-size: 2.5rem; margin-bottom: 15px;"><%= header_h1 || 'Thank You' %></h1>
            
            <p style="color: var(--text-muted); font-size: 1.1rem; line-height: 1.8; margin-bottom: 35px;"><%= body_content %></p>
            
            <div style="display: flex; gap: 15px; justify-content: center;">
                <a href="/" class="btn-primary" style="padding: 12px 30px;">Return Home</a>
                <a href="/fleet" class="btn-secondary" style="border-color: var(--primary-light); color: var(--primary-dark); padding: 12px 30px;">Browse Vehicles</a>
            </div>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
