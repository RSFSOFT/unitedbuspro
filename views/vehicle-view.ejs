<%- include('partials/header') %>

<!-- VEHICLE HERO -->
<section class="section-padding" style="background-image: linear-gradient(135deg, rgba(17, 24, 39, 0.9) 0%, rgba(31, 41, 55, 0.8) 100%), url('<%= vehicle.image %>?v=4'); background-size: cover; background-position: center; color: #ffffff; padding: 100px 30px 80px;">
    <div class="container">
        <div class="breadcrumbs">
            <a href="/"><i class="fa fa-home"></i> Home</a>
            <span class="separator">/</span>
            <a href="/fleet" style="color: rgba(255,255,255,0.7);">Our Fleet</a>
            <span class="separator">/</span>
            <span class="current"><%= vehicle.name %></span>
        </div>
        <h1 style="color: #ffffff; font-size: 2.8rem;"><%= vehicle.name %> Specifications</h1>
    </div>
</section>

<!-- VEHICLE DETAIL CONTENT -->
<section class="section-padding">
    <div class="container">
        <div class="hero-grid" style="align-items: start; gap: 50px;">
            <div>
                <div class="fleet-img-box" style="border-radius: var(--radius-md); overflow: hidden; box-shadow: var(--shadow-lg);">
                    <img src="<%= vehicle.image %>?v=4" class="fleet-img" alt="<%= vehicle.name %>">
                </div>
                
                <h2 style="font-size: 2rem; margin: 30px 0 15px;">Overview & Passenger Experience</h2>
                <p style="color: var(--text-muted); font-size: 1.05rem; margin-bottom: 20px;"><%= vehicle.description %></p>
                <p style="color: var(--text-muted); font-size: 1.05rem; margin-bottom: 30px;">This vehicle represents the highest tier of engineering standard in its category. Equipped with climate control variables, safety diagnostics, and comfortable seating positions, it ensures passenger relaxation over both local commuting routes and interstate charter travel schedules.</p>
            </div>

            <div>
                <!-- SPECIFICATIONS CARD -->
                <div class="admin-card" style="padding: 30px; border-radius: var(--radius-lg); position: sticky; top: 100px;">
                    <h3 style="margin-bottom: 25px; font-size: 1.4rem; border-bottom: 2px solid var(--bg-main); padding-bottom: 10px;">Capacity & Pricing</h3>
                    
                    <div style="display: flex; flex-direction: column; gap: 15px; margin-bottom: 30px;">
                        <div style="display: flex; justify-content: space-between; border-bottom: 1px solid rgba(0,0,0,0.05); padding-bottom: 8px;">
                            <span style="font-weight: 600; color: var(--text-muted);">Max Seating Capacity</span>
                            <span style="font-weight: 700; color: var(--primary-dark);"><i class="fa fa-users" style="color: var(--accent-gold); margin-right: 5px;"></i> <%= vehicle.capacity %></span>
                        </div>
                        <div style="display: flex; justify-content: space-between; border-bottom: 1px solid rgba(0,0,0,0.05); padding-bottom: 8px;">
                            <span style="font-weight: 600; color: var(--text-muted);">Baggage Limit</span>
                            <span style="font-weight: 700; color: var(--primary-dark);"><i class="fa fa-suitcase" style="color: var(--accent-gold); margin-right: 5px;"></i> <%= vehicle.bags %></span>
                        </div>
                        <div style="display: flex; justify-content: space-between; border-bottom: 1px solid rgba(0,0,0,0.05); padding-bottom: 8px;">
                            <span style="font-weight: 600; color: var(--text-muted);">Estimated Charter Rate</span>
                            <span style="font-weight: 700; color: var(--accent-gold); font-size: 1.15rem;"><%= vehicle.starting_rate %></span>
                        </div>
                        <div style="display: flex; justify-content: space-between; padding-bottom: 8px;">
                            <span style="font-weight: 600; color: var(--text-muted);">Safety Standard</span>
                            <span style="font-weight: 700; color: #03543f;"><i class="fa fa-check-circle" style="color: #03543f; margin-right: 5px;"></i> Meticulously Vetted</span>
                        </div>
                    </div>

                    <h4 style="font-size: 0.95rem; text-transform: uppercase; color: var(--text-muted); margin-bottom: 15px; font-weight: 700; letter-spacing: 0.5px;">Standard Amenities Included:</h4>
                    <div style="display: flex; flex-direction: column; gap: 10px; margin-bottom: 35px;">
                        <% vehicle.parsedAmenities.forEach(amenity => { %>
                            <span style="display: inline-flex; align-items: center; gap: 8px; font-size: 0.95rem; color: var(--primary-light); font-weight: 500;">
                                <i class="fa fa-check" style="color: var(--accent-gold);"></i> <%= amenity %>
                            </span>
                        <% }) %>
                    </div>

                    <a href="/reservation?vehicle=<%= vehicle.slug %>" class="btn-primary" style="display: block; text-align: center; font-size: 1.05rem; padding: 12px 0;">Request Rate Quote <i class="fa fa-arrow-right" style="margin-left: 5px;"></i></a>
                </div>
            </div>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
