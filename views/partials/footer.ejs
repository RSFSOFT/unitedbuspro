    <!-- FOOTER SECTION -->
    <footer>
        <div class="footer-grid">
            <div class="footer-col">
                <span class="logo-text" style="font-size: 1.8rem;">United<span>BusPro</span></span>
                <p style="margin-top: 15px; margin-bottom: 20px;">Setting the standard in charter coach rentals, corporate group shuttles, and event logistics across Texas and nationwide.</p>
                
                <!-- Social Media Icons -->
                <div style="display: flex; gap: 18px; margin-bottom: 20px; font-size: 1.3rem;">
                    <a href="https://facebook.com/unitedbuspro" target="_blank" rel="noopener noreferrer" style="color: rgba(255,255,255,0.6); transition: color 0.3s;" onmouseover="this.style.color='var(--accent-gold)'" onmouseout="this.style.color='rgba(255,255,255,0.6)'" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
                    <a href="https://twitter.com/unitedbuspro" target="_blank" rel="noopener noreferrer" style="color: rgba(255,255,255,0.6); transition: color 0.3s;" onmouseover="this.style.color='var(--accent-gold)'" onmouseout="this.style.color='rgba(255,255,255,0.6)'" aria-label="Twitter"><i class="fab fa-twitter"></i></a>
                    <a href="https://instagram.com/unitedbuspro" target="_blank" rel="noopener noreferrer" style="color: rgba(255,255,255,0.6); transition: color 0.3s;" onmouseover="this.style.color='var(--accent-gold)'" onmouseout="this.style.color='rgba(255,255,255,0.6)'" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
                    <a href="https://linkedin.com/company/unitedbuspro" target="_blank" rel="noopener noreferrer" style="color: rgba(255,255,255,0.6); transition: color 0.3s;" onmouseover="this.style.color='var(--accent-gold)'" onmouseout="this.style.color='rgba(255,255,255,0.6)'" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
                </div>

                <p style="font-size: 0.8rem; opacity: 0.6;">© 2026 United Bus Pro. All Rights Reserved. Fully Licensed, Bonded, and Insured.</p>
            </div>
            
            <div class="footer-col">
                <h4>Services</h4>
                <ul class="footer-links">
                    <li><a href="/services/airport-charter-bus-rentals">Charter Bus Rentals</a></li>
                    <li><a href="/services/employee-shuttles">Corporate Shuttles</a></li>
                    <li><a href="/services/k12-schools">Minibus Hire</a></li>
                    <li><a href="/services/wedding-shuttles">Wedding Guest Shuttles</a></li>
                    <li><a href="/services/k12-schools">School Field Trips</a></li>
                </ul>
            </div>
            
            <div class="footer-col">
                <h4>Company Links</h4>
                <ul class="footer-links">
                    <li><a href="/about">About Our Company</a></li>
                    <li><a href="/fleet">Our Fleet Showcase</a></li>
                    <li><a href="/blog">Travel Blog Guides</a></li>
                    <li><a href="/privacy-policy">Privacy Policies</a></li>
