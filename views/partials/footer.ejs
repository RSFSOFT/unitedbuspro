                </ul>
            </div>

            <div class="footer-col">
                <h4>Locations We Serve</h4>
                <ul class="footer-links">
                    <% if (typeof cities !== 'undefined' && cities) { %>
                        <% cities.slice(0, 5).forEach(c => { %>
                            <li><a href="/locations/<%= c.slug %>"><%= c.cityName %> Charter Bus</a></li>
                        <% }) %>
                    <% } %>
                </ul>
            </div>
            
            <div class="footer-col">
                <h4>Contact Us</h4>
                <p><i class="fa fa-phone" style="color: var(--accent-gold); margin-right: 8px;"></i> <%= settings.phone || '(202) 991-1203' %></p>
                <p><i class="fa fa-envelope" style="color: var(--accent-gold); margin-right: 8px;"></i> <%= settings.email || 'reservations@unitedbuspro.com' %></p>
                <p><i class="fa fa-map-marker-alt" style="color: var(--accent-gold); margin-right: 8px;"></i> <%= settings.address || 'Washington, DC' %></p>
                <p style="font-size: 0.8rem; color: var(--accent-gold-light);"><i class="fa fa-clock" style="margin-right: 5px;"></i> Dispatch available 24/7/365</p>
