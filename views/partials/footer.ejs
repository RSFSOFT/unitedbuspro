    <!-- STICKY MOBILE CTA BAR -->
    <div class="mobile-sticky-bar">
        <a href="tel:<%= (settings.phone || '+18004958017').replace(/[^0-9+]/g, '') %>" class="sticky-btn-left">
            <i class="fa fa-phone" style="margin-right: 8px;"></i> Call to Book
        </a>
        <a href="/reservation" class="sticky-btn-right">
            <i class="fa fa-envelope" style="margin-right: 8px;"></i> Get a Quote
        </a>
    </div>

    <!-- Cookie Consent Banner -->
    <div id="cookieConsentBanner" style="display: none; position: fixed; bottom: 85px; left: 20px; right: 20px; z-index: 99999; background: #ffffff; border: 1.5px solid rgba(0, 0, 0, 0.08); padding: 20px; border-radius: var(--radius-md); box-shadow: var(--shadow-xl); max-width: 500px; flex-direction: column; gap: 12px; font-family: var(--font-body);">
        <h4 style="font-size: 1.05rem; color: var(--primary-dark); font-family: var(--font-heading); font-weight: 700; margin: 0; display: flex; align-items: center; gap: 8px;"><i class="fa fa-cookie-bite" style="color: var(--accent-gold); font-size: 1.2rem;"></i> Cookie Consent & Visitor Tracking</h4>
        <p style="font-size: 0.82rem; color: var(--text-muted); line-height: 1.5; margin: 0;">We use cookies to analyze web traffic, personalize quotes, and optimize page performance. By clicking "Accept All", you consent to our website analytics and visitor tracking.</p>
        <div style="display: flex; gap: 10px; margin-top: 5px;">
            <button id="acceptCookiesBtn" class="btn-primary" style="flex: 1; padding: 10px 15px; font-size: 0.85rem; text-align: center; border-radius: var(--radius-sm); border: none; font-weight: 700; cursor: pointer; text-transform: uppercase;">Accept All</button>
            <button id="declineCookiesBtn" class="btn-secondary" style="flex: 1; padding: 10px 15px; font-size: 0.85rem; text-align: center; border-radius: var(--radius-sm); font-weight: 700; cursor: pointer; text-transform: uppercase; border-color: rgba(0,0,0,0.15); color: var(--text-muted); background: #f9fafb;">Decline</button>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const consentBanner = document.getElementById('cookieConsentBanner');
            const acceptBtn = document.getElementById('acceptCookiesBtn');
            const declineBtn = document.getElementById('declineCookiesBtn');
            
            if (consentBanner && acceptBtn && declineBtn) {
                const cookieConsent = localStorage.getItem('cookieConsentChoice');
                
                if (!cookieConsent) {
                    setTimeout(() => {
                        consentBanner.style.display = 'flex';
                    }, 1000);
                } else if (cookieConsent === 'accepted') {
                    initializeMockTracking();
                }
                
                acceptBtn.addEventListener('click', function() {
                    localStorage.setItem('cookieConsentChoice', 'accepted');
                    consentBanner.style.display = 'none';
                    initializeMockTracking();
                });
                
                declineBtn.addEventListener('click', function() {
                    localStorage.setItem('cookieConsentChoice', 'declined');
                    consentBanner.style.display = 'none';
                    console.log('Visitor declined cookie tracking.');
                });
            }
            
            function initializeMockTracking() {
                console.log('Visitor analytics and tracking cookies initialized.');
                let visits = parseInt(localStorage.getItem('mockTrackingVisits') || '0') + 1;
                localStorage.setItem('mockTrackingVisits', visits.toString());
            }
        });
    </script>

    <!-- Client-side JavaScript -->
    <script src="/js/main.js?v=3"></script>
</body>
</html>
