<%- include('partials/header') %>

<!-- SERVICE HERO -->
<%
  const imageMap = {
      // Services
      'airport-charter-bus-rentals': '/images/service-airport.webp',
      'camps': '/images/service-school.webp',
      'corporate-events': '/images/service-corporate.webp',
      'k12-schools': '/images/service-school.webp',
      'nonprofits': '/images/service-community.webp',
      'religious-groups': '/images/service-community.webp',
      'sports-teams': '/images/service-sports.webp',
      'travel-agents': '/images/service-corporate.webp',
      'university-bus-rentals': '/images/service-school.webp',
      'airport-shuttles': '/images/service-airport.webp',
      'campus-shuttles': '/images/service-school.webp',
      'construction-shuttles': '/images/service-emergency.webp',
      'employee-shuttles': '/images/service-corporate.webp',
      'hospitals--healthcare': '/images/service-emergency.webp',
      'k12-districts': '/images/service-school.webp',
      'wedding-shuttles': '/images/service-wedding.webp',
      'emergency-response': '/images/service-emergency.webp',
      'government--military': '/images/service-corporate.webp',
      'large-events': '/images/service-corporate.webp',
      'private-events': '/images/service-wedding.webp',
      'trade-shows--conferences': '/images/service-corporate.webp',
      'workforce-contingency': '/images/service-emergency.webp',
      // Info pages
      'about': 'https://images.unsplash.com/photo-1521791136064-7986c2920216?auto=format&fit=crop&w=1200&q=80',
      'contact': 'https://images.unsplash.com/photo-1423666639041-f509f75371c8?auto=format&fit=crop&w=1200&q=80',
      'careers': 'https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=1200&q=80',
      'reviews': 'https://images.unsplash.com/photo-1506869648501-55be6cf659f8?auto=format&fit=crop&w=1200&q=80',
      'sustainability': 'https://images.unsplash.com/photo-1466692476868-aef1dfb1e735?auto=format&fit=crop&w=1200&q=80',
      'privacy': 'https://images.unsplash.com/photo-1450133064473-71024230f91b?auto=format&fit=crop&w=1200&q=80',
      'terms': 'https://images.unsplash.com/photo-1589829545856-d10d557cf95f?auto=format&fit=crop&w=1200&q=80'
  };

  const name = (service.name || '').toLowerCase();
  const slug = (service.slug || '').toLowerCase();
  
  let heroBg = '/images/hero-bg.webp'; // Fallback
  
  if (slug && imageMap[slug]) {
      heroBg = imageMap[slug];
  } else if (name.includes('about')) {
      heroBg = imageMap['about'];
  } else if (name.includes('contact')) {
      heroBg = imageMap['contact'];
  } else if (name.includes('careers') || name.includes('recruitment') || name.includes('join')) {
      heroBg = imageMap['careers'];
  } else if (name.includes('review') || name.includes('testimonial') || name.includes('verified')) {
      heroBg = imageMap['reviews'];
  } else if (name.includes('sustainability') || name.includes('eco')) {
      heroBg = imageMap['sustainability'];
  } else if (name.includes('privacy')) {
      heroBg = imageMap['privacy'];
  } else if (name.includes('terms') || name.includes('condition')) {
      heroBg = imageMap['terms'];
  }
%>
<section class="section-padding" style="background-image: linear-gradient(135deg, rgba(17, 24, 39, 0.9) 0%, rgba(31, 41, 55, 0.8) 100%), url('<%= heroBg %>?v=4'); background-size: cover; background-position: center; color: #ffffff; padding: 100px 30px 80px;">
    <div class="container">
        <div class="breadcrumbs">
            <a href="/"><i class="fa fa-home"></i> Home</a>
            <span class="separator">/</span>
            <% if (name.includes('about') || name.includes('contact') || name.includes('join') || name.includes('careers') || name.includes('reviews') || name.includes('testimonials') || name.includes('sustainability') || name.includes('privacy') || name.includes('terms')) { %>
                <span style="color: rgba(255,255,255,0.7); text-transform: none;">Company</span>
            <% } else { %>
                <a href="/reservation" style="color: rgba(255,255,255,0.7);">Solutions</a>
            <% } %>
            <span class="separator">/</span>
            <span class="current"><%= service.name %></span>
        </div>
        <h1 style="color: #ffffff; font-size: 2.8rem; margin-bottom: 15px;"><%= service.name %></h1>
        <p style="color: var(--accent-gold-light); font-size: 1.15rem; font-weight: 600;"><i class="fa fa-users" style="margin-right: 5px;"></i> Capacity: <%= service.capacity %> | <i class="fa fa-dollar-sign" style="margin-left: 10px; margin-right: 5px;"></i> <%= service.price %></p>
    </div>
</section>

<!-- SERVICE DETAILS -->
<section class="section-padding">
    <div class="container">
        <div class="hero-grid" style="align-items: start; gap: 50px;">
            <div>
                <h2 style="font-size: 2rem; margin-bottom: 20px;">Service Overview</h2>
                <p style="color: var(--text-muted); font-size: 1.05rem; line-height: 1.8; margin-bottom: 30px;"><%= service.description %></p>
                
                <h3 style="font-size: 1.5rem; margin-bottom: 20px;">What We Provide</h3>
                <div style="display: flex; flex-direction: column; gap: 15px;">
                    <% service.parsedDetails.forEach(detail => { %>
                        <div style="display: flex; gap: 15px; align-items: start; background-color: var(--bg-card); padding: 15px; border-radius: var(--radius-md); border: 1px solid rgba(0,0,0,0.04); box-shadow: var(--shadow-sm);">
                            <span style="background-color: var(--accent-gold-light); color: var(--accent-gold); width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; flex-shrink: 0;"><i class="fa fa-check" style="font-size: 0.8rem;"></i></span>
                            <span style="font-size: 1rem; color: var(--text-muted); line-height: 1.5;"><%= detail %></span>
                        </div>
                    <% }) %>
                </div>
            </div>

            <div>
                <!-- SIDEBAR CTA CARD -->
                <div class="admin-card" style="padding: 30px; border-radius: var(--radius-lg); position: sticky; top: 100px; background-color: var(--primary-medium); color: #ffffff; border-color: rgba(255,255,255,0.05); box-shadow: var(--shadow-xl);">
                    <h3 style="color: #ffffff; margin-bottom: 20px; border-bottom: 1.5px solid rgba(255,255,255,0.1); padding-bottom: 10px;">Instant Charter Quote</h3>
                    <p style="color: var(--text-light); opacity: 0.85; margin-bottom: 25px; font-size: 0.95rem;">Skip phone calls and email delay. Input your group travel locations and dates to reserve this service immediately.</p>
                    
                    <ul style="list-style: none; margin-bottom: 35px; font-size: 0.95rem; color: var(--text-light); display: flex; flex-direction: column; gap: 12px;">
                        <li><i class="fa fa-check-circle" style="color: var(--accent-gold); margin-right: 8px;"></i> Vetted commercially-licensed chauffeurs</li>
                        <li><i class="fa fa-check-circle" style="color: var(--accent-gold); margin-right: 8px;"></i> Guaranteed 100% on-time arrival</li>
                        <li><i class="fa fa-check-circle" style="color: var(--accent-gold); margin-right: 8px;"></i> Clean, modern, safety-inspected buses</li>
                    </ul>

                    <a href="/reservation?service=<%= service.slug %>" class="btn-primary" style="display: block; text-align: center; font-size: 1.05rem; padding: 12px 0;">Request Service Quote <i class="fa fa-arrow-right" style="margin-left: 5px;"></i></a>
                </div>
            </div>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
